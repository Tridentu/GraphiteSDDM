; https://github.com/uiriansan/SilentSDDM

[SddmGreeterTheme]
Name=Graphite
Type=sddm-theme
Description=A very customizable SDDM theme fork that actually looks good. Includes Graphite configs as well.
License=GPL-3.0-or-later
Version=1.4.0
Theme-Id=silent
Theme-API=2.0
MainScript=Main.qml
Screenshot=docs/previews/default.png
TranslationsDirectory=translations
QtVersion=6

ConfigFile=configs/graphite.conf
